# انسخ هذا الملف باسم .env وعدّل القيم حسب بيئتك
# Copy this file to .env and edit the values for your environment

SECRET_KEY=please-change-this-to-a-random-secret-string

DB_USER=root
DB_PASSWORD=your_mysql_password
DB_HOST=localhost
DB_PORT=3306
DB_NAME=university_system

# اختياري: يمكنك تعيين رابط الاتصال الكامل بدلاً من الحقول أعلاه
# Optional: set the full connection string instead of the fields above
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/university_system?charset=utf8mb4
